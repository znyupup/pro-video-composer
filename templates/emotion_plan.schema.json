{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "emotion_plan",
  "description": "Agent 拆句标情绪后写入,narrate-emotion.sh 读这个文件逐段合成",
  "type": "object",
  "required": ["voice_id", "model", "speed", "segments"],
  "properties": {
    "voice_id": {
      "type": "string",
      "description": "用户复刻的音色 ID,如 NyxVoice2026"
    },
    "model": {
      "type": "string",
      "enum": ["speech-2.8-hd", "speech-2.6-hd"],
      "default": "speech-2.8-hd"
    },
    "speed": {
      "type": "number",
      "minimum": 1.0,
      "maximum": 1.3,
      "default": 1.2
    },
    "pitch": {
      "type": "integer",
      "const": 0,
      "description": "必须 0,任何非 0 都失真"
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "text", "emotion"],
        "properties": {
          "id": {"type": "integer", "minimum": 1},
          "text": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80,
            "description": "中文文本,无叹词,无 (breath)/(chuckle) 标签"
          },
          "emotion": {
            "type": "string",
            "enum": ["happy", "surprised", "calm", "sad", "fluent"],
            "description": "5 个安全 emotion;angry/disgusted/fearful 失真禁用"
          },
          "est_duration": {
            "type": "number",
            "minimum": 0.5,
            "maximum": 15.0,
            "description": "估计音频时长(秒),≤ 15s 硬约束"
          },
          "_note": {
            "type": "string",
            "description": "可选,agent 标注的语义/语气说明"
          }
        }
      }
    }
  },
  "_examples": [
    {
      "voice_id": "NyxVoice2026",
      "model": "speech-2.8-hd",
      "speed": 1.2,
      "pitch": 0,
      "segments": [
        {"id": 1, "text": "上期我准备撸起袖子做一期专业的视频。", "emotion": "happy",     "est_duration": 4.2, "_note": "铺垫"},
        {"id": 2, "text": "结果发给朋友看,他说有点怪。",            "emotion": "surprised", "est_duration": 3.5, "_note": "转折"}
      ]
    }
  ]
}
